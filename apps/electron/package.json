{
  "name": "@nanoleaf-jazz/electron",
  "version": "0.1.0",
  "description": "Desktop shell for Nanoleaf Jazz.",
  "homepage": "https://github.com/julianpas/nanoleaf_jazz",
  "author": {
    "name": "Julian Pastarmov",
    "email": "julian@pastarmov.net"
  },
  "private": true,
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node22 --format=cjs --external:electron --outfile=dist/main.cjs",
